<Page x:Class="TIAS.Pages.LoadLevel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d"
      Title="PlayLevel"
      Loaded="Page_Loaded"
      SizeChanged="Page_SizeChanged"
      Background="#FF1A2A3A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель информации -->
        <Border Grid.Row="0" 
                Background="#CC1E3F5A" 
                Padding="10"
                BorderBrush="LightBlue"
                BorderThickness="0,0,0,2">
            <Grid Margin="0,0,200,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Фаза игры -->
                <Border Grid.Column="0" 
                        Background="#4AFFFFFF" 
                        CornerRadius="5" 
                        Padding="10,5">
                    <TextBlock x:Name="PhaseTextBlock" 
                               Text="ВАШ ХОД" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="LightGreen"/>
                </Border>

                <!-- Информация о выбранном юните -->
                <Border Grid.Column="1" 
                        Background="#4AFFFFFF" 
                        CornerRadius="5" 
                        Padding="10,5"
                        Margin="10,0">
                    <TextBlock x:Name="UnitInfoTextBlock" 
                               Text="Выберите юнита" 
                               FontSize="14" 
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Игровое поле -->
        <ScrollViewer Grid.Row="1" 
                      x:Name="MainScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      PanningMode="Both"
                      ScrollChanged="MainScrollViewer_ScrollChanged">
            <Canvas x:Name="parrent" 
                    Background="Transparent"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"/>
        </ScrollViewer>

        <!-- Нижняя панель с сообщениями -->
        <Border Grid.Row="2" 
                Background="#CC1E3F5A" 
                Padding="10"
                BorderBrush="LightBlue"
                BorderThickness="0,2,0,0"
                Height="100">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" 
                           Text="Журнал событий" 
                           Foreground="LightBlue" 
                           FontWeight="Bold" 
                           Margin="0,0,0,5"/>

                <ScrollViewer Grid.Row="1" 
                              x:Name="MessagesScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="MessagesListBox" 
                             Background="Transparent" 
                             BorderThickness="0"
                             Foreground="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                           TextWrapping="Wrap" 
                                           Foreground="White"
                                           FontSize="11"
                                           Margin="0,2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>