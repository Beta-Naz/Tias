<Page x:Class="TIAS.Pages.LevelEdit"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TIAS.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="LevelEdit"
      Background="#FF1A2A3A"
      KeyDown="Page_KeyDown"
      Loaded="Page_Loaded">

    <Page.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="LightBlue"
                                BorderThickness="1"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Gold"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="LightGreen"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель инструментов -->
        <Border Grid.Column="0" 
                Background="#CC1E3F5A" 
                BorderBrush="LightBlue"
                BorderThickness="0,0,2,0"
                Padding="10">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Заголовок -->
                    <TextBlock Text="РЕДАКТОР КАРТ" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="LightBlue"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>

                    <!-- Параметры карты -->
                    <Border Background="#4AFFFFFF" 
                            CornerRadius="10" 
                            Padding="10"
                            Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Параметры карты" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <!-- Название карты -->
                            <TextBlock Text="Название:" Foreground="White" Margin="0,5,0,2"/>
                            <TextBox x:Name="MapNameTextBox" 
                                     Background="#4A000000"
                                     Foreground="White"
                                     BorderBrush="LightBlue"
                                     Padding="5"
                                     Text="Новая карта"/>

                            <StackPanel x:Name="SizePanel" Visibility="Visible">
                                <TextBlock Text="Ширина:" Foreground="White" Margin="0,10,0,2"/>
                                <TextBox x:Name="WidthTextBox" 
                                         Background="#4A000000"
                                         Foreground="White"
                                         BorderBrush="LightBlue"
                                         Padding="5"
                                         Text="10"/>

                                <TextBlock Text="Высота:" Foreground="White" Margin="0,10,0,2"/>
                                <TextBox x:Name="HeightTextBox" 
                                         Background="#4A000000"
                                         Foreground="White"
                                         BorderBrush="LightBlue"
                                         Padding="5"
                                         Text="10"/>
                                <Button Height="25" 
                                        Margin="0,10,0,0"
                                        FontWeight="Bold" Background="Green"
                                        Content="Создать карту" 
                                        Foreground="White"
                                        Click="Create_CLick"/>
                            </StackPanel>

                            <!-- ID карты (для редактирования) -->
                            <StackPanel x:Name="IdPanel" Visibility="Collapsed">
                                <TextBlock Text="ID карты:" Foreground="White" Margin="0,10,0,2"/>
                                <TextBox x:Name="MapIdTextBox" 
                                         Background="#4A000000"
                                         Foreground="White"
                                         BorderBrush="LightBlue"
                                         Padding="5"
                                         IsReadOnly="True"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Типы клеток -->
                    <Border Background="#4AFFFFFF" 
                            CornerRadius="10" 
                            Padding="10"
                            Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Типы клеток" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <WrapPanel>
                                <!-- Равнина -->
                                <Button x:Name="PlainButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#90EE90"
                                        Tag="Plain"
                                        Click="CellTypeButton_Click">
                                    <TextBlock Text="🌾" FontSize="20"/>
                                </Button>

                                <!-- Лес -->
                                <Button x:Name="ForestButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#228B22"
                                        Tag="Forest"
                                        Click="CellTypeButton_Click">
                                    <TextBlock Text="🌲" FontSize="20"/>
                                </Button>

                                <!-- Холмы -->
                                <Button x:Name="HillButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#A0522D"
                                        Tag="Hill"
                                        Click="CellTypeButton_Click">
                                    <TextBlock Text="⛰️" FontSize="20"/>
                                </Button>

                                <!-- Горы -->
                                <Button x:Name="MountainButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#808080"
                                        Tag="Mountain"
                                        Click="CellTypeButton_Click">
                                    <TextBlock Text="🏔️" FontSize="20"/>
                                </Button>

                                <!-- Вода -->
                                <Button x:Name="WaterButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#40A4DF"
                                        Tag="Water"
                                        Click="CellTypeButton_Click">
                                    <TextBlock Text="💧" FontSize="20"/>
                                </Button>

                                <!-- Город -->
                                <Button x:Name="CityButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#A9A9A9"
                                        Tag="City"
                                        Click="CellTypeButton_Click">
                                    <TextBlock Text="🏙️" FontSize="20"/>
                                </Button>
                            </WrapPanel>

                            <TextBlock x:Name="CurrentCellTypeText" 
                                       Text="Выбрано: Равнина" 
                                       Foreground="White"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Юниты СССР -->
                    <Border Background="#4AFFFFFF" 
                            CornerRadius="10" 
                            Padding="10"
                            Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Юниты СССР" 
                                       Foreground="Green" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <WrapPanel>
                                <Button x:Name="SovietTankButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Tank,USSR"
                                        Click="UnitButton_Click">
                                    <Image Source="/Images/Unit/T34.png" Width="30" Height="30"/>
                                </Button>

                                <Button x:Name="SovietInfantryButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Infanity,USSR"
                                        Click="UnitButton_Click">
                                    <Image Source="/Images/Unit/infanity_ussr.png" Width="30" Height="30"/>
                                </Button>

                                <Button x:Name="SovietArtilleryButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Artillery,USSR"
                                        Click="UnitButton_Click">
                                    <Image Source="/Images/Unit/art1.png" Width="30" Height="30"/>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Юниты Германии -->
                    <Border Background="#4AFFFFFF" 
                            CornerRadius="10" 
                            Padding="10"
                            Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Юниты Германии" 
                                       Foreground="Red" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <WrapPanel>
                                <Button x:Name="GermanTankButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Tank,Germany"
                                        Click="UnitButton_Click">
                                    <Image Source="/Images/Unit/Panjer.png" Width="30" Height="30"/>
                                </Button>

                                <Button x:Name="GermanInfantryButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Infanity,Germany"
                                        Click="UnitButton_Click">
                                    <Image Source="/Images/Unit/infanity_germany.png" Width="30" Height="30"/>
                                </Button>

                                <Button x:Name="GermanArtilleryButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Artillery,Germany"
                                        Click="UnitButton_Click">
                                    <Image Source="/Images/Unit/art2.png" Width="30" Height="30"/>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- Инструменты -->
                    <Border Background="#4AFFFFFF" 
                            CornerRadius="10" 
                            Padding="10"
                            Margin="0,0,0,20">

                        <StackPanel>
                            <TextBlock Text="Инструменты" 
                                       Foreground="White" 
                                       FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <WrapPanel>
                                <Button x:Name="SelectButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Select"
                                        Click="ToolButton_Click">
                                    <TextBlock Text="🔍" FontSize="20"/>
                                </Button>

                                <Button x:Name="EraserButton" 
                                        Style="{StaticResource ToolButtonStyle}"
                                        Background="#4A000000"
                                        Tag="Eraser"
                                        Click="ToolButton_Click">
                                    <TextBlock Text="🧹" FontSize="20"/>
                                </Button>
                            </WrapPanel>

                            <TextBlock x:Name="CurrentToolText" 
                                       Text="Инструмент: Кисть" 
                                       Foreground="White"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки действий -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">

                        <Button Content="Сохранить" 
                                Width="100" Height="40"
                                Background="Green"
                                Foreground="White"
                                FontWeight="Bold"
                                Margin="5"
                                Click="SaveButton_Click"/>

                        <Button Content="Отмена" 
                                Width="100" Height="40"
                                Background="DarkRed"
                                Foreground="White"
                                FontWeight="Bold"
                                Margin="5"
                                Click="CancelButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Правая панель с картой -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя информационная панель -->
            <Border Grid.Row="0" 
                    Background="#CC1E3F5A" 
                    Padding="10"
                    BorderBrush="LightBlue"
                    BorderThickness="0,0,0,2">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="InfoTextBlock" 
                               Text="Кликните на клетку для размещения"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" Width="150" Background="Red" 
                            Content="Delete" Foreground="White" FontWeight="Bold"
                            Click="Delete_Click"/>
                </Grid>

                
            </Border>

            <!-- Карта -->
            <ScrollViewer Grid.Row="1" 
                          x:Name="MainScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="#4A000000">

                <Canvas x:Name="MapCanvas" 
                        Background="Transparent"
                        MouseLeftButtonDown="Canvas_MouseLeftButtonDown"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>