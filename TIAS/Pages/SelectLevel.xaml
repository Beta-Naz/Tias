<Page x:Class="TIAS.Pages.SelectLevel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TIAS.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SelectLevel">

    <Page.Background>
        <ImageBrush ImageSource="/Images/Background/BackgroundSelectLevel.png" Stretch="UniformToFill"/>
    </Page.Background>

    <Grid>
        <!-- Затемняющий слой -->
        <Rectangle Fill="#CC000000"/>

        <!-- Декоративные элементы (снежинки/звезды) -->
        <Grid>
            <Grid.Resources>
                <Storyboard x:Key="FloatingAnimation" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetProperty="(FrameworkElement.RenderTransform).(TranslateTransform.Y)" 
                                     From="-10" To="10" Duration="0:0:3"/>
                </Storyboard>
            </Grid.Resources>
        </Grid>

        <!-- Заголовок страницы -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0">
            <TextBlock Text="ВЫБОР УРОВНЯ" 
                       FontFamily="Georgia"
                       FontSize="36" 
                       FontWeight="Bold"
                       Foreground="LightBlue"
                       HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect ShadowDepth="3" Color="Black" BlurRadius="8"/>
                </TextBlock.Effect>
            </TextBlock>

            <Rectangle Height="3" Width="300" Fill="LightBlue" Margin="0,5,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Основной контейнер для списка уровней и информации -->
        <Grid Margin="50,120,50,50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="500"/>
            </Grid.ColumnDefinitions>

            <!-- Левая колонка: список уровней -->
            <Border Grid.Column="0" 
                    Background="#CC1E3F5A" 
                    CornerRadius="20" 
                    Margin="0,0,20,0"
                    BorderBrush="LightBlue"
                    BorderThickness="2">

                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" Color="Black" BlurRadius="15" Opacity="0.5"/>
                </Border.Effect>

                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок списка -->
                    <TextBlock Grid.Row="0" 
                               Text="ДОСТУПНЫЕ УРОВНИ" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="LightBlue"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"/>

                    <!-- Список уровней (ScrollViewer) -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Background="Transparent">
                        <StackPanel x:Name="parrent">

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Кнопка добавления уровня -->
                    <Button Grid.Row="2" 
                            Content="+ ДОБАВИТЬ УРОВЕНЬ" 
                            Height="50"
                            Margin="0,15,0,0"
                            Background="#AA0047AB"
                            Foreground="White"
                            BorderBrush="LightBlue"
                            BorderThickness="2"
                            FontSize="14"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Click="Add_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="Gold"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Правая колонка: информация о выбранном уровне -->
            <Border Grid.Column="1" 
                    Background="#CC1E3F5A" 
                    CornerRadius="20"
                    BorderBrush="LightBlue"
                    BorderThickness="2"
                    Padding="20">

                <Border.Effect>
                    <DropShadowEffect ShadowDepth="5" Color="Black" BlurRadius="15" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <TextBlock Grid.Row="0" 
                               Text="ИНФОРМАЦИЯ ОБ УРОВНЕ" 
                               FontSize="18" 
                               FontWeight="Bold"
                               Foreground="LightBlue"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Контейнер для пользовательского элемента LevelInfo -->
                    <Border Grid.Row="1" 
                            Background="#4AFFFFFF" 
                            CornerRadius="15"
                            Padding="20"
                            VerticalAlignment="Top">
                        <StackPanel>
                            <!-- Здесь будет ваш пользовательский элемент -->
                            <TextBlock x:Name="PanelNoSeletLevel"
                                       Text="Выберите уровень для просмотра информации" 
                                       TextWrapping="Wrap"
                                       Foreground="#CCFFFFFF"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       Margin="0,20"/>
                            <StackPanel x:Name="PanelSeletLevel" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Наименование уровня:" 
                                         TextWrapping="Wrap"
                                         Foreground="#CCFFFFFF"
                                         FontSize="14"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding LevelName}" 
                                         TextWrapping="Wrap"
                                         Foreground="#CCFFFFFF"
                                         FontSize="14"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="5,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Размер уровня:" 
                                         TextWrapping="Wrap"
                                         Foreground="#CCFFFFFF"
                                         FontSize="14"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding SizeLevel}" 
                                         TextWrapping="Wrap"
                                         Foreground="#CCFFFFFF"
                                         FontSize="14"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="5,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Количество юнитов:" 
                                         TextWrapping="Wrap"
                                         Foreground="#CCFFFFFF"
                                         FontSize="14"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding CountUnits}" 
                                         TextWrapping="Wrap"
                                         Foreground="#CCFFFFFF"
                                         FontSize="14"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Top"
                                         Margin="5,0"/>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!-- Кнопки действий (появляются при выборе уровня) -->
                    <StackPanel Grid.Row="2" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Center"
                                Margin="0,20,0,0">

                        <!-- Кнопка ИГРАТЬ -->
                        <Button Content="ИГРАТЬ" 
                                Width="120" 
                                Height="45"
                                Margin="0,0,10,0"
                                Background="#AA0B6000"
                                Foreground="White"
                                BorderBrush="LightBlue"
                                BorderThickness="2"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Play_Click">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Gold"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Кнопка РЕДАКТОР -->
                        <Button Content="РЕДАКТОР" 
                                Width="120" 
                                Height="45"
                                Background="#AA0047AB"
                                Foreground="White"
                                BorderBrush="LightBlue"
                                BorderThickness="2"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="Edit_Click">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="Gold"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        
                    </StackPanel>
                    
                    <!-- Подсказка (отображается когда уровень не выбран) -->
                    <TextBlock Grid.Row="2" 
                               Text="Выберите уровень из списка" 
                               Foreground="#80FFFFFF"
                               FontSize="12"
                               FontStyle="Italic"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Bottom"
                               Margin="0,0,0,10"
                               Visibility="Collapsed">
                        <!-- Visibility менять в коде при выборе уровня -->
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
        <Button Content="НАЗАД" 
                HorizontalAlignment="Left" 
                VerticalAlignment="Bottom" 
                Margin="10,0,0,417"
                Background="Transparent"
                Foreground="White"
                BorderBrush="LightBlue"
                BorderThickness="1"
                Cursor="Hand" Height="23" Width="54"
                Click="Back_Click">

            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4AFFFFFF"/>
                            <Setter Property="Foreground" Value="Gold"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Page>